---
import metrics from '../data/metrics.json';
---

<section class="section metrics-section" id="metrics">
  <div class="metrics__ornament metrics__ornament--circle"></div>
  <div class="metrics__ornament metrics__ornament--square"></div>
  <div class="container--narrow">
    <div class="section-header reveal">
      <span class="section-label">{metrics.sectionLabel}</span>
      <h2 class="section-title">
        {metrics.title}
      </h2>
      <p class="section-subtitle">
        {metrics.subtitle}
      </p>
    </div>

    <!-- Leading -->
    <div class="metrics__group reveal">
      <div class="metrics__group-header">
        <span class="metrics__badge">Leading</span>
        <span class="metrics__ask">is AI actually doing the work?</span>
      </div>
      <div class="metrics__grid">
        {metrics.leading.map((m) => (
          <article class="metric">
            <div class="metric__top">
              <span class="metric__target">{m.target}</span>
            </div>
            <div class="metric__body">
              <h3 class="metric__name">{m.metric}</h3>
              {m.label && <span class="metric__label">{m.label}</span>}
              <p class="metric__desc">{m.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Diamond Divider -->
    <div class="metrics__diamond reveal">
      <span class="metrics__diamond-line"></span>
      <span class="metrics__diamond-icon">◆</span>
      <span class="metrics__diamond-line"></span>
    </div>

    <!-- Lagging -->
    <div class="metrics__group reveal reveal-delay-2">
      <div class="metrics__group-header">
        <span class="metrics__badge metrics__badge--lagging">Lagging</span>
        <span class="metrics__ask">is it showing up in the business?</span>
      </div>
      <div class="metrics__grid metrics__grid--lagging">
        {metrics.lagging.map((m) => (
          <article class="metric metric--lagging">
            <div class="metric__top">
              <span class="metric__target metric__target--lagging">{m.target}</span>
            </div>
            <div class="metric__body">
              <h3 class="metric__name">{m.metric}</h3>
              <p class="metric__desc">{m.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Vanity Callout -->
    <div class="metrics__callout reveal reveal-delay-3">
      <div class="metrics__callout-body">
        <span class="metrics__callout-icon">✕</span>
        <div class="metrics__callout-text">
          <strong>Revenue growth</strong> without AI doing the actual work isn't product-market fit — it's a consulting firm with VC funding.
        </div>
        <span class="metrics__callout-stamp">Not all growth is good growth</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section background ── */
  .metrics-section {
    position: relative;
  }

  .metrics-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 45% at 30% 20%, var(--glow-1) 0%, transparent 100%),
      radial-gradient(ellipse 35% 30% at 70% 80%, var(--glow-2) 0%, transparent 100%),
      radial-gradient(ellipse 30% 25% at 50% 50%, var(--glow-3) 0%, transparent 100%);
    pointer-events: none;
    mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    -webkit-mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .metrics__ornament {
    position: absolute;
    pointer-events: none;
  }

  .metrics__ornament--circle {
    width: 180px;
    height: 180px;
    top: 4%;
    right: 2%;
    border-radius: 50%;
    border: 1px solid var(--accent-subtle);
    opacity: 0.12;
    animation: sectionFloat 26s ease-in-out infinite;
  }

  .metrics__ornament--circle::before {
    content: '';
    position: absolute;
    inset: 20%;
    border: 1px solid var(--accent-muted);
    border-radius: 50%;
    opacity: 0.5;
  }

  .metrics__ornament--square {
    width: 100px;
    height: 100px;
    bottom: 12%;
    left: 3%;
    border: 1px solid var(--navy);
    border-radius: 0;
    opacity: 0.1;
    animation: sectionFloat 30s ease-in-out infinite reverse;
  }

  .metrics__ornament--square::before {
    content: '';
    position: absolute;
    inset: 15%;
    border: 1px solid var(--navy);
    opacity: 0.5;
  }

  /* ── Group Header ── */
  .metrics__group-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
    flex-wrap: wrap;
  }

  .metrics__badge {
    font-size: var(--text-sm);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.4rem 1.25rem;
    border-radius: 4px;
    color: var(--bg-base);
    background: var(--accent);
    flex-shrink: 0;
  }

  .metrics__badge--lagging {
    background: var(--highlight);
  }

  .metrics__ask {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    letter-spacing: -0.02em;
  }

  /* ── Grid ── */
  .metrics__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .metrics__grid--lagging {
    grid-template-columns: repeat(3, 1fr);
  }

  /* ── Metric Card ── */
  .metric {
    padding: var(--space-2xl) var(--space-xl);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    transition: all var(--transition);
  }

  .metric:hover {
    border-color: var(--highlight-muted);
    background: var(--bg-elevated);
    transform: translateY(-2px);
  }

  .metric__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .metric__target {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--accent);
    padding: 0.3rem 0.9rem 0.35rem;
    border: 1px solid var(--accent-subtle);
    border-radius: 4px;
    background: var(--accent-light-subtle);
    transition: all var(--transition);
  }

  .metric:hover .metric__target {
    background: var(--highlight-surface);
    border-color: var(--highlight);
  }

  .metric__target--lagging {
    color: var(--highlight);
    border-color: var(--highlight);
    background: var(--highlight-glow-subtle);
  }

  .metric:hover .metric__target--lagging {
    background: var(--highlight-glow-mid);
    border-color: var(--highlight);
  }

  .metric__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .metric__name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    transition: color var(--transition);
  }

  .metric:hover .metric__name {
    color: var(--highlight);
  }

  .metric--lagging:hover .metric__name {
    color: var(--highlight);
  }

  .metric__label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-muted);
  }

  .metric__desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.55;
    max-width: 45ch;
  }

  /* ── Diamond Divider ── */
  .metrics__diamond {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    padding-block: var(--space-3xl);
  }

  .metrics__diamond-line {
    flex: 1;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--accent-muted), transparent);
    opacity: 0.4;
  }

  .metrics__diamond-icon {
    color: var(--accent);
    font-size: var(--text-xl);
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* ── Callout ── */
  .metrics__callout {
    margin-top: var(--space-3xl);
  }

  .metrics__callout-body {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xl);
    padding: var(--space-2xl);
    background: linear-gradient(135deg, var(--callout-1) 0%, var(--callout-2) 100%);
    border-left: 4px solid var(--highlight);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    position: relative;
    overflow: hidden;
  }

  .metrics__callout-icon {
    font-size: var(--text-2xl);
    flex-shrink: 0;
    margin-top: 0.05em;
    color: var(--highlight);
    line-height: 1;
  }

  .metrics__callout-text {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.65;
    flex: 1;
  }

  .metrics__callout-text strong {
    color: var(--text-primary);
    font-weight: 700;
  }

  .metrics__callout-stamp {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--highlight);
    text-align: right;
    max-width: 18ch;
    line-height: 1.4;
    padding-left: var(--space-xl);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .metrics__callout-stamp {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .metrics__grid,
    .metrics__grid--lagging {
      grid-template-columns: repeat(2, 1fr);
    }

    .metrics__callout-body {
      flex-wrap: wrap;
      gap: var(--space-md);
    }

    .metrics__callout-stamp {
      display: block;
      text-align: left;
      padding-left: 0;
      max-width: none;
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .metrics__grid,
    .metrics__grid--lagging {
      grid-template-columns: 1fr;
    }

    .metrics__ask {
      font-size: var(--text-base);
    }

    .metric {
      padding: var(--space-xl) var(--space-lg);
    }

    .metric__name {
      font-size: var(--text-xl);
    }

    .metrics__callout-body {
      padding: var(--space-lg);
    }

    .metrics__diamond {
      padding-block: var(--space-2xl);
    }

    .metrics__ornament--circle {
      width: 100px;
      height: 100px;
    }

    .metrics__ornament--square {
      display: none;
    }
  }
</style>
