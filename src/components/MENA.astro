---
import mena from '../data/mena.json';
---

<section class="section mena" id="mena">
  <div class="mena__bg"></div>
  <div class="mena__ornament mena__ornament--circle"></div>
  <div class="mena__ornament mena__ornament--square"></div>
  <div class="container--narrow">
    <div class="section-header reveal">
      <span class="section-label">{mena.sectionLabel}</span>
      <h2 class="section-title">
        {mena.title}
      </h2>
      <p class="section-subtitle">
        {mena.subtitle}
      </p>
    </div>

    <div class="mena-grid">
      <div class="mena-block reveal">
        <span class="mena-block__label">Strategic Partners</span>
        <div class="mena-block__items">
          {mena.strategicPartners.map((p) => (
            <div class="mena-block__item">
              <div class="mena-block__item-line"></div>
              <div>
                <h3 class="mena-block__name">{p.name}</h3>
                <span class="mena-block__role">{p.role}</span>
                <p class="mena-block__desc">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mena-block reveal reveal-delay-1">
        <span class="mena-block__label mena-block__label--alt">Market Access</span>
        <div class="mena-block__items">
          {mena.marketAccess.map((p) => (
            <div class="mena-block__item">
              <div class="mena-block__item-line mena-block__item-line--alt"></div>
              <div>
                <h3 class="mena-block__name">{p.name}</h3>
                <span class="mena-block__role">{p.role}</span>
                <p class="mena-block__desc">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .mena {
    position: relative;
  }

  .mena__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 50% at 15% 30%, var(--glow-1) 0%, transparent 100%),
      radial-gradient(ellipse 40% 35% at 80% 70%, var(--glow-2) 0%, transparent 100%),
      radial-gradient(ellipse 30% 25% at 55% 20%, var(--glow-3) 0%, transparent 100%);
    pointer-events: none;
    mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    -webkit-mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .mena__ornament {
    position: absolute;
    pointer-events: none;
  }

  .mena__ornament--circle {
    width: 170px;
    height: 170px;
    top: 6%;
    right: 3%;
    border-radius: 50%;
    border: 1px solid var(--accent-subtle);
    opacity: 0.12;
    animation: sectionFloat 24s ease-in-out infinite;
  }

  .mena__ornament--circle::before {
    content: '';
    position: absolute;
    inset: 20%;
    border: 1px solid var(--accent-muted);
    border-radius: 50%;
    opacity: 0.5;
  }

  .mena__ornament--square {
    width: 100px;
    height: 100px;
    bottom: 8%;
    left: 2%;
    border: 1px solid var(--navy);
    border-radius: 0;
    opacity: 0.1;
    animation: sectionFloat 28s ease-in-out infinite reverse;
  }

  .mena__ornament--square::before {
    content: '';
    position: absolute;
    inset: 15%;
    border: 1px solid var(--navy);
    opacity: 0.5;
  }

  /* ── Top accent line ── */
  .mena::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--highlight-glow-subtle), transparent);
    pointer-events: none;
  }

  .mena-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .mena-block {
    position: relative;
  }

  .mena-block__label {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    padding-bottom: var(--space-sm);
    margin-bottom: var(--space-lg);
    border-bottom: 2px solid var(--accent-subtle);
  }

  .mena-block__label--alt {
    color: var(--navy);
    border-bottom-color: var(--navy);
  }

  .mena-block__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .mena-block__item {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
    transition: all var(--transition);
  }

  .mena-block__item:hover {
    padding-left: var(--space-sm);
  }

  .mena-block__item-line {
    width: 3px;
    flex-shrink: 0;
    background: linear-gradient(to bottom, var(--accent-muted), transparent);
    border-radius: 2px;
    transition: opacity var(--transition);
  }

  .mena-block__item-line--alt {
    background: linear-gradient(to bottom, var(--navy), transparent);
  }

  .mena-block__item:hover .mena-block__item-line {
    opacity: 0.6;
  }

  .mena-block__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xs);
    line-height: 1.15;
  }

  .mena-block__role {
    display: block;
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--accent);
    line-height: 1.4;
  }

  .mena-block__item:has(.mena-block__item-line--alt) .mena-block__role {
    color: var(--navy);
  }

  .mena-block__desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-top: var(--space-xs);
  }

  @media (max-width: 768px) {
    .mena-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .mena-block__item {
      padding: var(--space-md) 0;
    }

    .mena__ornament--circle {
      width: 100px;
      height: 100px;
    }

    .mena__ornament--square {
      display: none;
    }
  }
</style>
