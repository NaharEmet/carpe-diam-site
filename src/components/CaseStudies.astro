---
import cases from '../data/cases.json';
---

<section class="section engagements-section" id="engagements">
  <div class="engagements__bg"></div>
  <div class="engagements__ornament engagements__ornament--circle"></div>
  <div class="engagements__ornament engagements__ornament--square"></div>
  <div class="container--narrow">
    <div class="section-header reveal">
      <span class="section-label">Live Engagements</span>
      <h2 class="section-title">
        Built. Deployed. <em>Delivering.</em>
      </h2>
      <p class="section-subtitle">
        Real AI products in production — not slide decks. Every project sharpens our methodology.
      </p>
    </div>

    <div class="engagements">
      {cases.map((c, i) => (
        <article class="engagement reveal" class:list={{ [`reveal-delay-${i + 1}`]: true }}>
          <div class="engagement__index">
            <span class="engagement__num">{String(i + 1).padStart(2, '0')}</span>
            <div class="engagement__line"></div>
          </div>
          <div class="engagement__body">
            <div class="engagement__header">
              <span class="engagement__tag">{c.tag}</span>
              <h3 class="engagement__client">{c.client}</h3>
              <p class="engagement__desc">{c.desc}</p>
            </div>
            <ul class="engagement__features">
              {c.results.map((r) => (
                <li class="engagement__feature">{r}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .engagements-section {
    position: relative;
  }

  .engagements__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 50% at 10% 30%, var(--glow-1) 0%, transparent 100%),
      radial-gradient(ellipse 40% 35% at 85% 65%, var(--glow-2) 0%, transparent 100%),
      radial-gradient(ellipse 30% 30% at 55% 15%, var(--glow-3) 0%, transparent 100%);
    pointer-events: none;
    mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    -webkit-mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .engagements__ornament {
    position: absolute;
    pointer-events: none;
  }

  .engagements__ornament--circle {
    width: 190px;
    height: 190px;
    top: 4%;
    right: 2%;
    border-radius: 50%;
    border: 1px solid var(--accent-subtle);
    opacity: 0.12;
    animation: sectionFloat 25s ease-in-out infinite;
  }

  .engagements__ornament--circle::before {
    content: '';
    position: absolute;
    inset: 20%;
    border: 1px solid var(--accent-muted);
    border-radius: 50%;
    opacity: 0.5;
  }

  .engagements__ornament--square {
    width: 95px;
    height: 95px;
    bottom: 8%;
    left: 2%;
    border: 1px solid var(--navy);
    border-radius: 0;
    opacity: 0.1;
    animation: sectionFloat 30s ease-in-out infinite reverse;
  }

  .engagements__ornament--square::before {
    content: '';
    position: absolute;
    inset: 15%;
    border: 1px solid var(--navy);
    opacity: 0.5;
  }

  .engagements {
    display: flex;
    flex-direction: column;
  }

  .engagement {
    display: flex;
    gap: var(--space-xl);
    padding: var(--space-2xl) 0;
    transition: all var(--transition);
  }

  .engagement + .engagement {
    border-top: 1px solid var(--border);
  }

  .engagement:hover {
    padding-left: var(--space-sm);
  }

  .engagement__index {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 3rem;
    flex-shrink: 0;
  }

  .engagement__num {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--accent-muted);
    letter-spacing: 0.03em;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 50%;
    transition: all var(--transition);
  }

  .engagement:hover .engagement__num {
    border-color: var(--highlight-muted);
    color: var(--highlight);
    background: var(--highlight-surface);
  }

  .engagement__line {
    width: 1px;
    flex: 1;
    min-height: 1rem;
    background: linear-gradient(to bottom, var(--border), transparent);
  }

  .engagement:last-child .engagement__line {
    display: none;
  }

  .engagement__body {
    flex: 1;
    min-width: 0;
  }

  .engagement__header {
    margin-bottom: var(--space-lg);
  }

  .engagement__tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: var(--space-xs);
  }

  .engagement__client {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: var(--space-xs);
  }

  .engagement__desc {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.5;
  }

  .engagement__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .engagement__feature {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    padding-left: var(--space-xl);
    position: relative;
  }

  .engagement__feature::before {
    content: '→';
    position: absolute;
    left: 0;
    top: 0.05em;
    color: var(--accent-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .engagement {
      flex-direction: column;
      gap: var(--space-md);
      padding: var(--space-xl) 0;
    }

    .engagement__index {
      flex-direction: row;
      width: auto;
      gap: var(--space-md);
    }

    .engagement__line {
      width: 100%;
      height: 1px;
      flex: none;
      min-height: 0;
    }

    .engagement__client {
      font-size: var(--text-2xl);
    }

    .engagements__ornament--circle {
      width: 110px;
      height: 110px;
    }

    .engagements__ornament--square {
      display: none;
    }
  }
</style>
