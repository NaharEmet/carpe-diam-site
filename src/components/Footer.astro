---
import site from '../data/site.json';
---

<footer class="footer">
  <div class="footer__top-decor"></div>
  <div class="footer__bg"></div>
  <div class="footer__ornament"></div>
  <div class="container--narrow">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <img src="/logo.svg" alt="Carpediem AI" class="footer__logo-img" />
          <span class="footer__logo-text">Carpediem AI</span>
        </a>
        <p class="footer__tagline">
          {site.footerTagline}
        </p>
        <p class="footer__desc">
          {site.footerDesc}
        </p>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">Navigate</h4>
        <nav class="footer__nav">
          {site.footerLinks.map((link) => (
            <a href={link.href} class="footer__link">{link.label}</a>
          ))}
        </nav>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">Approach</h4>
        <nav class="footer__nav">
          <a href="/approach" class="footer__link">Why Carpediem</a>
          <a href="/approach" class="footer__link">Success Metrics</a>
          <a href="/approach" class="footer__link">MENA/KSA</a>
        </nav>
      </div>
    </div>

    <div class="footer__security reveal">
      <span class="footer__security-label">Security &amp; Compliance</span>
      <div class="footer__security-badges">
        {site.securityBadges.map((badge) => (
          <span class="footer__badge">{badge}</span>
        ))}
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">
        {site.copyright}
      </p>
      <p class="footer__tagline-small">
        Enterprise AI services
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: var(--space-3xl) var(--space-xl);
    background: var(--bg-base);
    position: relative;
  }

  .footer__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 40% 50% at 15% 30%, var(--glow-1-mid) 0%, transparent 100%),
      radial-gradient(ellipse 25% 30% at 80% 70%, var(--glow-2-mid) 0%, transparent 100%);
    pointer-events: none;
    mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    -webkit-mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .footer__ornament {
    position: absolute;
    bottom: 5%;
    right: 3%;
    width: 80px;
    height: 80px;
    border: 1px solid var(--navy);
    border-radius: 0;
    opacity: 0.06;
    pointer-events: none;
    animation: sectionFloat 30s ease-in-out infinite reverse;
  }

  .footer__ornament::before {
    content: '';
    position: absolute;
    inset: 15%;
    border: 1px solid var(--navy);
    opacity: 0.5;
  }

  .footer__top-decor {
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(to right, transparent, var(--accent-muted), var(--accent), var(--highlight-glow-strong), transparent);
    opacity: 0.5;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .footer__logo-img {
    height: 2rem;
    width: auto;
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--text-primary);
    margin-top: var(--space-md);
    max-width: 35ch;
    line-height: 1.5;
    font-weight: 500;
  }

  .footer__desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-top: var(--space-sm);
    max-width: 40ch;
    line-height: 1.6;
  }

  .footer__col-title {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-lg);
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    transition: color var(--transition);
    width: fit-content;
  }

  .footer__link:hover {
    color: var(--highlight);
  }

  .footer__bottom {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer__copy {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .footer__tagline-small {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  .footer__security {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .footer__security-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .footer__security-badges {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .footer__badge {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-secondary);
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    transition: all var(--transition);
  }

  .footer__badge:hover {
    border-color: var(--highlight-muted);
    color: var(--highlight);
    background: var(--highlight-surface);
  }

  .footer__badge-dot {
    color: var(--accent-muted);
    margin: 0 0.15rem;
  }

  .footer__bottom {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }
    .footer__tagline-small {
      display: none;
    }
  }
</style>
