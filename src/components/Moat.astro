---
import moat from '../data/moat.json';
---

<section class="moats" id="moats">
  <div class="moats__bg"></div>
  <div class="moats__ornament moats__ornament--circle"></div>
  <div class="moats__ornament moats__ornament--square"></div>
  <div class="container--narrow">
    <div class="section-header reveal">
      <span class="section-label">{moat.label}</span>
      <h2 class="section-title">
        {moat.title}
      </h2>
    </div>

    <div class="moat__statement reveal reveal-delay-1">
      <div class="moat__watermark">◈</div>
      <div class="moat__border"></div>
      <div class="moat__body">
        <p class="moat__lead">
          {moat.lead}
        </p>
        <p class="moat__clincher">
          <strong>{moat.clincher}</strong>
        </p>
        <div class="moat__pillars">
          {moat.pillars.map((p, i) => (
            <span class="moat__pillar" class:list={{ [`moat__pillar--${moat.pillarStyles[i]}`]: true }}>{p}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .moats {
    padding-block: var(--space-4xl);
    position: relative;
  }

  .moats::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 24px;
    background: var(--bg-deep);
    -webkit-mask: radial-gradient(14px at 20px -2px, black 99%, transparent 100%);
    -webkit-mask-size: 40px 100%;
    -webkit-mask-repeat: repeat-x;
    mask: radial-gradient(14px at 20px -2px, black 99%, transparent 100%);
    mask-size: 40px 100%;
    mask-repeat: repeat-x;
    pointer-events: none;
    z-index: 2;
  }

  .moats__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 80% at 30% 50%, var(--glow-1-dim) 0%, transparent 100%),
      radial-gradient(ellipse 35% 45% at 70% 60%, var(--glow-2-dim) 0%, transparent 100%),
      radial-gradient(ellipse 30% 30% at 50% 20%, var(--glow-3-dim) 0%, transparent 100%);
    pointer-events: none;
    mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    -webkit-mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .moats__ornament {
    position: absolute;
    pointer-events: none;
  }

  .moats__ornament--circle {
    width: 200px;
    height: 200px;
    top: 5%;
    left: 2%;
    border-radius: 50%;
    border: 1px solid var(--accent-subtle);
    opacity: 0.12;
    animation: sectionFloat 26s ease-in-out infinite;
  }

  .moats__ornament--circle::before {
    content: '';
    position: absolute;
    inset: 20%;
    border: 1px solid var(--accent-muted);
    border-radius: 50%;
    opacity: 0.5;
  }

  .moats__ornament--square {
    width: 100px;
    height: 100px;
    bottom: 10%;
    right: 3%;
    border: 1px solid var(--navy);
    border-radius: 0;
    opacity: 0.1;
    animation: sectionFloat 32s ease-in-out infinite reverse;
  }

  .moats__ornament--square::before {
    content: '';
    position: absolute;
    inset: 15%;
    border: 1px solid var(--navy);
    opacity: 0.5;
  }

  .moat__statement {
    display: flex;
    gap: var(--space-2xl);
    padding: var(--space-3xl) var(--space-2xl) var(--space-3xl) 0;
    position: relative;
    transition: all var(--transition);
  }

  .moat__watermark {
    position: absolute;
    right: -1rem;
    bottom: -1rem;
    font-size: clamp(8rem, 15vw, 18rem);
    color: var(--accent);
    opacity: 0.025;
    pointer-events: none;
    line-height: 1;
    user-select: none;
    transition: opacity var(--transition), transform var(--transition);
  }

  .moat__statement:hover .moat__watermark {
    opacity: 0.05;
    transform: scale(1.05) rotate(5deg);
  }

  .moat__border {
    position: relative;
    width: 6px;
    flex-shrink: 0;
    background: linear-gradient(to bottom, var(--highlight), var(--highlight-glow-strong), transparent);
    border-radius: 3px;
    opacity: 0.6;
    transition: opacity var(--transition);
  }

  .moat__statement:hover .moat__border {
    opacity: 1;
  }

  .moat__body {
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .moat__lead {
    font-size: var(--text-lg);
    color: var(--text-primary);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .moat__clincher {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: var(--space-2xl);
    padding: var(--space-lg) 0 var(--space-lg) var(--space-xl);
    border-left: 2px solid var(--accent-subtle);
    font-style: italic;
    letter-spacing: -0.01em;
  }

  .moat__clincher strong {
    color: var(--accent);
    font-weight: 500;
    font-style: normal;
  }

  .moat__pillars {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .moat__pillar {
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 0.5rem 1.15rem;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: all var(--transition);
  }

  .moat__pillar--gold {
    color: var(--accent);
    border: 1px solid var(--accent-subtle);
  }

  .moat__pillar--gold:hover {
    background: var(--highlight-surface);
    border-color: var(--highlight-muted);
  }

  .moat__pillar--navy {
    color: var(--navy);
    border: 1px solid var(--navy-muted);
  }

  .moat__pillar--navy:hover {
    background: var(--navy-glow-subtle);
    border-color: var(--navy-glow-mid);
  }

  @media (max-width: 768px) {
    .moat__statement {
      flex-direction: column;
      padding: var(--space-xl) 0;
    }
    .moat__border {
      width: 100%;
      height: 4px;
      background: linear-gradient(to right, var(--accent), var(--navy-glow-strong), transparent);
    }
    .moat__lead {
      font-size: var(--text-base);
    }
    .moat__clincher {
      font-size: var(--text-lg);
      padding: var(--space-md) 0 var(--space-md) var(--space-lg);
    }
    .moat__watermark {
      display: none;
    }
    .moats__ornament--circle {
      width: 120px;
      height: 120px;
    }
    .moats__ornament--square {
      display: none;
    }
  }
</style>
