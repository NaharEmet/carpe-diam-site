---
import steps from '../data/framework.json';
---

<section class="section framework-section" id="framework">
  <div class="framework__bg"></div>
  <div class="framework__ornament framework__ornament--circle"></div>
  <div class="framework__ornament framework__ornament--square"></div>
  <div class="container--narrow">
    <div class="section-header reveal">
      <span class="section-label">AINS Framework</span>
      <h2 class="section-title">
        5-Point <em>AI Migration Framework</em>
      </h2>
      <p class="section-subtitle">
        From legacy systems to live agentic operations — a repeatable, low-risk path to AI-native enterprise.
      </p>
    </div>

    <div class="framework reveal">
      {steps.map((step, i) => (
        <div class="framework__step" class:list={{ [`reveal-delay-${i + 1}`]: true, 'framework__step--right': i % 2 !== 0 }}>
          <div class="framework__bg-num">{step.num}</div>
          <div class="framework__content">
            <h3 class="framework__title">{step.title}</h3>
            <span class="framework__subtitle">{step.subtitle}</span>
            <p class="framework__desc">{step.desc}</p>
            <span class="framework__action">{step.action} →</span>
          </div>
          <div class="framework__marker">
            <span class="framework__num">{step.num}</span>
            {i < steps.length - 1 && <div class="framework__line"></div>}
          </div>
          <div class="framework__spacer"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .framework-section {
    position: relative;
  }

  .framework__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 15% 25%, var(--glow-1) 0%, transparent 100%),
      radial-gradient(ellipse 40% 35% at 80% 70%, var(--glow-2) 0%, transparent 100%),
      radial-gradient(ellipse 30% 30% at 50% 10%, var(--glow-3) 0%, transparent 100%);
    pointer-events: none;
    mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    -webkit-mask-image: 
      radial-gradient(ellipse 100% 20% at 50% 0%, transparent 0%, black 100%),
      radial-gradient(ellipse 100% 20% at 50% 100%, transparent 0%, black 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .framework__ornament {
    position: absolute;
    pointer-events: none;
  }

  .framework__ornament--circle {
    width: 200px;
    height: 200px;
    top: 3%;
    left: 1%;
    border-radius: 50%;
    border: 1px solid var(--accent-subtle);
    opacity: 0.12;
    animation: sectionFloat 26s ease-in-out infinite;
  }

  .framework__ornament--circle::before {
    content: '';
    position: absolute;
    inset: 20%;
    border: 1px solid var(--accent-muted);
    border-radius: 50%;
    opacity: 0.5;
  }

  .framework__ornament--square {
    width: 110px;
    height: 110px;
    bottom: 10%;
    right: 4%;
    border: 1px solid var(--navy);
    border-radius: 0;
    opacity: 0.1;
    animation: sectionFloat 32s ease-in-out infinite reverse;
  }

  .framework__ornament--square::before {
    content: '';
    position: absolute;
    inset: 15%;
    border: 1px solid var(--navy);
    opacity: 0.5;
  }

  .framework {
    position: relative;
  }

  .framework__step {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-xl);
    align-items: start;
    position: relative;
  }

    .framework__bg-num {
    display: none;
  }

  .framework__content {
    grid-column: 1;
    grid-row: 1;
    position: relative;
  }

  .framework__marker {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.25rem;
  }

  .framework__spacer {
    grid-column: 3;
    grid-row: 1;
  }

  .framework__step--right .framework__content {
    grid-column: 3;
    grid-row: 1;
  }

  .framework__step--right .framework__spacer {
    grid-column: 1;
    grid-row: 1;
  }

  .framework__num {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    border: 2px solid var(--accent-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--accent);
    flex-shrink: 0;
    transition: all var(--transition);
    background: transparent;
    position: relative;
    z-index: 2;
  }

  .framework__step:hover .framework__num {
    background: var(--highlight);
    border-color: var(--highlight);
    color: var(--bg-base);
    box-shadow: 0 0 40px var(--highlight-surface), 0 0 80px var(--highlight-glow-mid);
    transform: scale(1.08);
  }

  .framework__line {
    width: 3px;
    flex: 1;
    background: linear-gradient(to bottom, var(--highlight), var(--highlight-glow-strong), transparent);
    min-height: 3rem;
    border-radius: 2px;
    margin-top: -0.25rem;
  }

  .framework__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .framework__step:hover .framework__title {
    color: var(--highlight);
  }

  .framework__subtitle {
    display: block;
    font-size: var(--text-base);
    color: var(--accent);
    font-weight: 500;
    margin-top: var(--space-xs);
  }

  .framework__desc {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-top: var(--space-sm);
    line-height: 1.6;
  }

  .framework__action {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent);
    margin-top: var(--space-md);
    padding: 0.4rem 1rem;
    border: 1px solid var(--accent-subtle);
    border-radius: 100px;
    transition: all var(--transition);
  }

  .framework__action:hover {
    background: var(--highlight-surface);
    border-color: var(--highlight-muted);
    padding-right: 1.25rem;
  }

  @media (min-width: 1024px) {
  .framework__bg-num {
      display: block;
      position: absolute;
      font-family: var(--font-display);
      font-size: clamp(6rem, 8vw, 12rem);
      font-weight: 400;
      color: var(--accent);
      opacity: 0.03;
      pointer-events: none;
      line-height: 1;
      top: -0.15em;
      left: -0.05em;
      z-index: 0;
      transition: opacity var(--transition), transform var(--transition);
      user-select: none;
    }

    .framework__step--right .framework__bgNum {
      left: auto;
      right: -0.05em;
    }

    .framework__step:hover .framework__bgNum {
      opacity: 0.06;
      transform: scale(1.04);
    }
  }

  @media (max-width: 768px) {
    .framework__step {
      grid-template-columns: auto 1fr;
      gap: var(--space-md);
    }
    .framework__content {
      grid-column: 2;
    }
    .framework__marker {
      grid-column: 1;
    }
    .framework__spacer {
      display: none;
    }
    .framework__step--right .framework__content {
      grid-column: 2;
    }
    .framework__step--right .framework__spacer {
      display: none;
    }
    .framework__num {
      width: 3rem;
      height: 3rem;
      font-size: var(--text-sm);
    }
    .framework__title {
      font-size: var(--text-xl);
    }
    .framework__subtitle {
      font-size: var(--text-sm);
    }
    .framework__desc {
      font-size: var(--text-sm);
    }
    .framework__ornament--circle {
      width: 120px;
      height: 120px;
    }
    .framework__ornament--square {
      display: none;
    }
  }
</style>
