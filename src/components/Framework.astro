---

const steps = [
  {
    num: '01',
    title: 'Diagnose',
    subtitle: 'AI Readiness Assessment',
    desc: 'Analyze data, systems, processes, and team readiness.',
    action: 'Readiness Scorecard',
  },
  {
    num: '02',
    title: 'Design',
    subtitle: 'AI-Native Strategic Planning',
    desc: 'Architecture design, agent blueprints, and capability mapping.',
    action: 'CBM Design Tool',
  },
  {
    num: '03',
    title: 'Validate',
    subtitle: 'Controlled AI Validation',
    desc: 'Validate AI accuracy and confidence through shadow-mode testing.',
    action: 'Voice AI Simulator',
  },
  {
    num: '04',
    title: 'Deploy',
    subtitle: 'Phased AI Deployment',
    desc: 'Progressive rollout tied to milestone outcomes.',
    action: 'Deploy Accelerator',
  },
  {
    num: '05',
    title: 'Scale',
    subtitle: 'Full-Scale AI Operations',
    desc: 'Managed operations or Build-Operate-Transfer.',
    action: 'Ops Dashboard',
  },
];
---

<section class="section" id="framework">
  <div class="container--narrow">
    <div class="section-header reveal">
      <span class="section-label">AINS Framework</span>
      <h2 class="section-title">
        5-Point <em>AI Migration Framework</em>
      </h2>
      <p class="section-subtitle">
        From legacy systems to live agentic operations — a repeatable, low-risk path to AI-native enterprise.
      </p>
    </div>

    <div class="framework reveal">
      {steps.map((step, i) => (
        <div class="framework__step" class:list={{ [`reveal-delay-${i + 1}`]: true, 'framework__step--right': i % 2 !== 0 }}>
          <div class="framework__bg-num">{step.num}</div>
          <div class="framework__content">
            <h3 class="framework__title">{step.title}</h3>
            <span class="framework__subtitle">{step.subtitle}</span>
            <p class="framework__desc">{step.desc}</p>
            <span class="framework__action">⚡ {step.action} →</span>
          </div>
          <div class="framework__marker">
            <span class="framework__num">{step.num}</span>
            {i < steps.length - 1 && <div class="framework__line"></div>}
          </div>
          <div class="framework__spacer"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .framework {
    position: relative;
  }

  .framework__step {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-xl);
    align-items: start;
    position: relative;
  }

    .framework__bg-num {
    display: none;
  }

  .framework__content {
    grid-column: 1;
    grid-row: 1;
    position: relative;
  }

  .framework__marker {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.25rem;
  }

  .framework__spacer {
    grid-column: 3;
    grid-row: 1;
  }

  .framework__step--right .framework__content {
    grid-column: 3;
    grid-row: 1;
  }

  .framework__step--right .framework__spacer {
    grid-column: 1;
    grid-row: 1;
  }

  .framework__num {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    border: 2px solid var(--accent-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--accent);
    flex-shrink: 0;
    transition: all var(--transition);
    background: transparent;
    position: relative;
    z-index: 2;
  }

  .framework__step:hover .framework__num {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg-base);
    box-shadow: 0 0 40px var(--accent-surface), 0 0 80px oklch(0.64 0.20 65 / 0.1);
    transform: scale(1.08);
  }

  .framework__line {
    width: 3px;
    flex: 1;
    background: linear-gradient(to bottom, var(--accent), oklch(0.58 0.16 38 / 0.5), transparent);
    min-height: 3rem;
    border-radius: 2px;
    margin-top: -0.25rem;
  }

  .framework__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .framework__step:hover .framework__title {
    color: var(--accent);
  }

  .framework__subtitle {
    display: block;
    font-size: var(--text-base);
    color: var(--accent);
    font-weight: 500;
    margin-top: var(--space-xs);
  }

  .framework__desc {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-top: var(--space-sm);
    line-height: 1.6;
  }

  .framework__action {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent);
    margin-top: var(--space-md);
    padding: 0.4rem 1rem;
    border: 1px solid var(--accent-subtle);
    border-radius: 100px;
    transition: all var(--transition);
  }

  .framework__action:hover {
    background: var(--accent-surface);
    border-color: var(--accent-muted);
    padding-right: 1.25rem;
  }

  @media (min-width: 1024px) {
  .framework__bg-num {
      display: block;
      position: absolute;
      font-family: var(--font-display);
      font-size: clamp(6rem, 8vw, 12rem);
      font-weight: 400;
      color: var(--accent);
      opacity: 0.03;
      pointer-events: none;
      line-height: 1;
      top: -0.15em;
      left: -0.05em;
      z-index: 0;
      transition: opacity var(--transition), transform var(--transition);
      user-select: none;
    }

    .framework__step--right .framework__bgNum {
      left: auto;
      right: -0.05em;
    }

    .framework__step:hover .framework__bgNum {
      opacity: 0.06;
      transform: scale(1.04);
    }
  }

  @media (max-width: 768px) {
    .framework__step {
      grid-template-columns: auto 1fr;
      gap: var(--space-md);
    }
    .framework__content {
      grid-column: 2;
    }
    .framework__marker {
      grid-column: 1;
    }
    .framework__spacer {
      display: none;
    }
    .framework__step--right .framework__content {
      grid-column: 2;
    }
    .framework__step--right .framework__spacer {
      display: none;
    }
    .framework__num {
      width: 3rem;
      height: 3rem;
      font-size: var(--text-sm);
    }
    .framework__title {
      font-size: var(--text-xl);
    }
    .framework__subtitle {
      font-size: var(--text-sm);
    }
    .framework__desc {
      font-size: var(--text-sm);
    }
  }
</style>
