---
import '../styles/global.css';
export interface Props {
  title?: string;
}

const { title = 'Carpediem AI — Seize the day. Ship the AI.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="Enterprise AI done differently. We design, build, and operate production-grade agentic AI systems that compress timelines and deliver measurable outcomes." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@300..700&family=Prata&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
